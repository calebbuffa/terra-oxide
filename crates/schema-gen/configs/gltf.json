  "customTypes": {
    "AccessorComponentType": {
      "kind": "enum",
      "numeric": true,
      "doc": "Data type of accessor components (5120: BYTE, 5121: UNSIGNED_BYTE, 5122: SHORT, 5123: UNSIGNED_SHORT, 5125: UNSIGNED_INT, 5126: FLOAT).",
      "variants": [
        "Byte",
        "UnsignedByte",
        "Short",
        "UnsignedShort",
        "UnsignedInt",
        "Float"
      ],
      "numericValues": {
        "Byte": 5120,
        "UnsignedByte": 5121,
        "Short": 5122,
        "UnsignedShort": 5123,
        "UnsignedInt": 5125,
        "Float": 5126
      }
    },
    "AccessorType": {
      "kind": "enum",
      "doc": "Accessor type: specifies whether data is scalars, vectors, or matrices.",
      "variants": [
        "SCALAR",
        "VEC2",
        "VEC3",
        "VEC4",
        "MAT2",
        "MAT3",
        "MAT4"
      ]
    },
    "AnimationInterpolation": {
      "kind": "enum",
      "doc": "Interpolation algorithm for animation samplers.",
      "variants": [
        "LINEAR",
        "STEP",
        "CUBICSPLINE"
      ]
    },
    "AnimationPath": {
      "kind": "enum",
      "doc": "Animated property name (translation, rotation, scale, or weights).",
      "variants": [
        "translation",
        "rotation",
        "scale",
        "weights"
      ]
    },
    "CameraType": {
      "kind": "enum",
      "doc": "Camera projection type.",
      "variants": [
        "perspective",
        "orthographic"
      ]
    },
    "PrimitiveMode": {
      "kind": "enum",
      "numeric": true,
      "doc": "Primitive rendering mode (0: POINTS, 1: LINES, 2: LINE_LOOP, 3: LINE_STRIP, 4: TRIANGLES, 5: TRIANGLE_STRIP, 6: TRIANGLE_FAN).",
      "variants": [
        "Points",
        "Lines",
        "LineLoop",
        "LineStrip",
        "Triangles",
        "TriangleStrip",
        "TriangleFan"
      ],
      "numericValues": {
        "Points": 0,
        "Lines": 1,
        "LineLoop": 2,
        "LineStrip": 3,
        "Triangles": 4,
        "TriangleStrip": 5,
        "TriangleFan": 6
      }
    },
    "AlphaMode": {
      "kind": "enum",
      "doc": "Alpha blending mode for materials.",
      "variants": [
        "OPAQUE",
        "MASK",
        "BLEND"
      ]
    }
